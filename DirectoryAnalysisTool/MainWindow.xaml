<Window x:Class="DirectoryAnalysisTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Directory Analysis Tool" Height="600" Width="1000">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" Background="#F0F0F0">

			<Button Content="📁 Select Folder..." Command="{Binding SelectFolderCommand}" Padding="10,5" />

			<Button Content="⬆️ Up" Command="{Binding NavigateUpCommand}" Padding="10,5" Margin="5,0,0,0" ToolTip="Go up one level to the parent directory" />

			<TextBlock Text="{Binding CurrentPath}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold" />

		</StackPanel>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="1*" />
				<ColumnDefinition Width="5" />
				<ColumnDefinition Width="2*" />
			</Grid.ColumnDefinitions>

			<TreeView Grid.Column="0" ItemsSource="{Binding RootDirectories}" Margin="5"
          SelectedItemChanged="TreeView_SelectedItemChanged">
				<TreeView.ItemContainerStyle>
					<Style TargetType="TreeViewItem">
						<Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
						<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
						<EventSetter Event="Selected" Handler="TreeViewItem_Selected" />
					</Style>
				</TreeView.ItemContainerStyle>
				<TreeView.ItemTemplate>
					<HierarchicalDataTemplate ItemsSource="{Binding Subdirectories}">

						<StackPanel Orientation="Horizontal" Background="Transparent"
									Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">

							<StackPanel.ContextMenu>
								<ContextMenu>
									<MenuItem Header="Set as Root"
											  Command="{Binding PlacementTarget.Tag.ZoomInCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
											  CommandParameter="{Binding FullPath}">
										<MenuItem.Icon>
											<TextBlock Text="🔍" />
										</MenuItem.Icon>
									</MenuItem>

									<MenuItem Header="Open In File Explorer"
											  Command="{Binding PlacementTarget.Tag.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
											  CommandParameter="{Binding FullPath}">
										<MenuItem.Icon>
											<TextBlock Text="📁" />
										</MenuItem.Icon>
									</MenuItem>
								</ContextMenu>
							</StackPanel.ContextMenu>

							<TextBlock Text="📁 " />
							<TextBlock Text="{Binding Name}" FontWeight="Bold" />
							<TextBlock Text="  [" Foreground="DarkGray" />
							<TextBlock Text="{Binding FormattedSize}" Foreground="DarkMagenta" Margin="0,0,5,0" />
							<TextBlock Text="|" Foreground="DarkGray" Margin="0,0,5,0" />
							<TextBlock Text="{Binding Percentage, StringFormat={}{0:0.0}%}" Foreground="Blue" />
							<TextBlock Text="]" Foreground="DarkGray" />
						</StackPanel>

					</HierarchicalDataTemplate>
				</TreeView.ItemTemplate>
			</TreeView>

			<GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray" />

			<ItemsControl Grid.Column="2" x:Name="TreemapControl" ItemsSource="{Binding VisualNodes}" SizeChanged="TreemapControl_SizeChanged" Margin="5">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas Background="#1E1E1E" ClipToBounds="True" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderBrush="{Binding NodeBorderBrush}" BorderThickness="{Binding NodeBorderThickness}" Background="{Binding Color}">

							<Border.InputBindings>
								<MouseBinding MouseAction="LeftClick"
											  Command="{Binding DataContext.SelectNodeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
											  CommandParameter="{Binding FullPath}"/>

								<MouseBinding MouseAction="LeftDoubleClick"
											  Command="{Binding DataContext.ZoomInCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
											  CommandParameter="{Binding FullPath}"/>
							</Border.InputBindings>

							<TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="4"/>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="{Binding X}" />
						<Setter Property="Canvas.Top" Value="{Binding Y}" />
						<Setter Property="Width" Value="{Binding Width}" />
						<Setter Property="Height" Value="{Binding Height}" />
					</Style>
				</ItemsControl.ItemContainerStyle>
			</ItemsControl>
		</Grid>
	</Grid>
</Window>